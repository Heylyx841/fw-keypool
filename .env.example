# ============================================================
# fw-keypool 环境变量模板
# 复制为 .env 并填入实际值。切勿提交 .env 到版本库。
# ============================================================

# ---------- 造号端 registrar ----------
# 邮箱池文件路径（CSV 或 JSON），相对项目根
EMAIL_POOL_FILE=emails.csv

# POP 登录连续失败阈值：超过此数判定为假邮箱并禁用（不再用于注册）
# 默认 3，即第 4 次失败触发禁用（config.yaml mail.pop_login_fail_threshold 同名覆盖）
MAIL_POP_LOGIN_FAIL_THRESHOLD=3

# 并发注册数（默认 1 串行最稳；建议 1-3，过高触发风控）
REGISTRAR_CONCURRENCY=1

# 单邮箱注册超时（秒）
REGISTRAR_TIMEOUT=300

# 失败重试次数
REGISTRAR_MAX_RETRY=3

# 代理（可选，格式 http://user:pass@host:port，留空则直连）
# 注意：config.yaml 的 proxy_pool 已默认 http://127.0.0.1:3067（karing 代理出口）。
# 此处 HTTP_PROXY 仅在 proxy_pool 为空时作为兜底单代理。
# 建议：不同邮箱走不同出口 IP，降低封 IP 风险
HTTP_PROXY=
HTTPS_PROXY=

# ---------- Karing 代理控制（每注册一个 key 换一个可用节点） ----------
# Karing 是 Clash 兼容（sing-box 核心）图形代理客户端。开启后每注册一个 key 前通过
# 控制端口切换到一个延迟 <KARING_MAX_LATENCY_MS 的可用节点，代理出口端口不变。
# 关闭(KARING_ENABLED=false)则沿用 proxy_pool 固定出口不切换。
KARING_ENABLED=true
KARING_API_HOST=127.0.0.1
KARING_API_PORT=3057              # 控制端口（Clash 风格 RESTful API）
KARING_PROXY_PORT=3067            # 代理出口端口（与 proxy_pool 一致）
KARING_DASHBOARD_PORT=3072        # 在线面板端口
KARING_CLUSTER_PORT=3050          # 集群服务端口
KARING_SELECTOR_NAME=             # Selector 组名，空=自动发现第一个 Selector 组
KARING_SECRET=                    # 控制端口 secret（karing service.json "secret" 字段），无则 API 401
KARING_DELAY_TEST_URL=https://www.gstatic.com/generate_204
KARING_MAX_LATENCY_MS=400         # 节点延迟阈值（ms）
KARING_NODE_TIMEOUT_MS=5000       # 单节点延迟测试超时（ms）
KARING_SWITCH_PER_KEY=true        # true=每注册一个 key 换一个节点

# 浏览器 headless（true/false）
# true=不弹出浏览器窗口（无人值守，默认），false=弹窗可观察。
# headless 间歇返回降级 HTML 页，但代码已有降级页检测 + max_page_retry=3 重试兜底。
HEADLESS=true

# ---------- Fireworks 配置 ----------
# OpenAI 兼容端点（New API 渠道 base_url 用）
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ---------- New API 号池承载层 ----------
# 本机 Docker 部署地址
NEWAPI_BASE_URL=http://127.0.0.1:3000
# New API 管理员用户名/密码（首次启动初始化 root）
NEWAPI_ADMIN_USER=root
NEWAPI_ADMIN_PASS=changeme123
# 管理员 access_token（sync_channels 用，首次登录后生成）
NEWAPI_ACCESS_TOKEN=

# ---------- 打码（默认不启用，可插拔） ----------
CAPTCHA_STRATEGY=none
# 若启用 2captcha
TWO_CAPTCHA_API_KEY=
