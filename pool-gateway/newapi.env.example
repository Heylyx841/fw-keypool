# New API 运行期配置（sync_channels.py 读取）
# 首次 docker compose up 后，访问 http://127.0.0.1:3000 用 root/changeme123 登录，
# 在「个人设置」生成 Access Token，填入下面。

# New API 服务地址
NEWAPI_BASE_URL=http://127.0.0.1:3000

# 管理员 access token（用于调 /api/channel/ 录入渠道）
NEWAPI_ACCESS_TOKEN=

# Fireworks OpenAI 兼容端点（渠道 base_url）
# 注意：去掉末尾 /v1，New API 会自动补 /v1/chat/completions，否则双重 /v1 报 404
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference

# 渠道级自定义请求头（JSON 字符串，New API 转发时附加到上游 Fireworks）。
# 确保所有 Fireworks 接口（含特殊标头）都能正常转发。留空则不附加。
# 客户端请求自带的任意标头 New API 默认透传（Authorization 被渠道 key 替换）。
# 例：FIREWORKS_CHANNEL_HEADERS={"X-Fireworks-Gen-Random-Seed":"42"}
FIREWORKS_CHANNEL_HEADERS=

# 渠道默认配置
CHANNEL_TYPE=1
CHANNEL_GROUP=default
CHANNEL_PRIORITY=0
CHANNEL_WEIGHT=100

# 健康巡检间隔（秒）
HEALTH_CHECK_INTERVAL=600

# 失活渠道自动剔除
AUTO_DISABLE_ON_FAIL=true

# sticky 转发代理配置（sticky_proxy.py 读取）
# 同 key 优先（命中 Fireworks token 缓存）+ 连续失败超 N 次永久禁用该 key（429 同样计入；全禁用时重置轮换）
STICKY_PROXY_HOST=127.0.0.1
STICKY_PROXY_PORT=3001
STICKY_FAIL_THRESHOLD=3
STICKY_UPSTREAM_TIMEOUT=120
